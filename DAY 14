//USING SPACE 

class Solution {
  public:
    int countStrings(int n) {
        // code here
        if(n==1) return 2;
        if(n==2) return 3;
        
        int prev1 = 2;
        int prev2 = 3;
        
        for(int i = 3; i<=n; i++){
            int curr = prev1 + prev2;
            prev2 = prev1;
            prev1 = curr;
        }
        return prev1;
    }
};





