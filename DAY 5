#include <iostream>
using namespace std;

class Node {
public:
    int data;
    Node* next;

    Node(int data) {
        this->data = data;
        this->next = NULL;
    }
};

Node* head = NULL;

void deleteAtPosition(int position) {

    if(head == NULL || position <= 0) {
        cout << "Invalid Operation" << endl;
        return;
    }

    if(position == 1) {
        head = head->next;
        return;
    }

    Node* temp = head;

    for(int i = 1; i < position - 1; i++) {

        if(temp->next == NULL) {
            cout << "Position out of range" << endl;
            return;
        }

        temp = temp->next;
    }

    if(temp->next == NULL) {
        cout << "Position out of range" << endl;
        return;
    }

    temp->next = temp->next->next;
}

void display() {

    Node* temp = head;

    while(temp != NULL) {
        cout << temp->data << " -> ";
        temp = temp->next;
    }

    cout << "NULL" << endl;
}

