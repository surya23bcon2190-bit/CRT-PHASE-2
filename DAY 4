#include<bits/stdc++.h>
using namespace std;
 
 int binarySearch(vector<int> &arr, int target){
    int low = 0;
    int high = arr.size() -1;
    while(low <= high){
        int mid = low + (high-low)/2;
        
        if(arr[mid] == target){
            return mid;
        }
        if(arr[mid] < target){
            low = mid + 1;
        }
        else{
            high = mid-1;
        }
    }
    return -1;
}
    
int main(){
    vector<int> arr ={2,3,4,6,8,10};
    int target = 10;
    int result = binarySearch(arr, target);
    
    if(result = -1){
        cout << "Element not found";
    }
    else{
    cout<< "Element found at "<< result;
    }
    return 0;
}




